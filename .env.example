# OpenAI（必須）
OPENAI_API_KEY=

# 任意: 評価に使うモデル（省略時 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# ローカル開発: データ保存先（省略時はプロジェクト直下 uploads/ reports/）
# Render では未設定で /tmp/pilates-session-review を使用
# DATA_DIR=/tmp/pilates-session-review

# Supabase（添削履歴の保存・閲覧）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Render / 本番（Render が自動設定）
# PORT=10000
# RENDER=true
